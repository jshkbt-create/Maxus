# ==========================================
# Manus Agent System - Environment Variables
# ==========================================

# Application
APP_NAME="Manus Agent System"
DEBUG=false
ENVIRONMENT=production

# Secret key (generate with: openssl rand -hex 32)
SECRET_KEY=your-secret-key-here-change-in-production

# LLM Provider
# Options: "openai" or "anthropic"
LLM_PROVIDER=anthropic
LLM_MODEL=claude-3-haiku-20240307
LLM_MAX_TOKENS=2000
LLM_TEMPERATURE=0.7

# API Keys (set at least one)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# NewsAPI key for fetching real news
NEWS_API_KEY=

# Database
# On Render.com: automatically set from PostgreSQL service via render.yaml
# For local development: use SQLite
DATABASE_URL=sqlite:///./manus_agent.db
# For local PostgreSQL: postgresql://user:pass@localhost/manus

# Redis
# On Render.com: automatically set from Redis service via render.yaml
# For local development: use local Redis
REDIS_URL=redis://localhost:6379/0

# CORS (comma-separated origins, or * for all)
ALLOWED_ORIGINS=["*"]

# Social Media (optional - add later if needed)
# TWITTER_API_KEY=
# TWITTER_API_SECRET=
# FACEBOOK_ACCESS_TOKEN=
