# ==========================================
# Maxus Agent System - Environment Variables
# Copy this file to .env and fill in values
# On Render.com, set these in the dashboard
# ==========================================

# Application
APP_NAME="Manus Agent System"
DEBUG=false
ENVIRONMENT=production

# Secret key (auto-generated by render.yaml, but set manually for local)
SECRET_KEY=your-secret-key-here-change-in-production

# LLM Provider
# Options: "openai" or "anthropic"
LLM_PROVIDER=openai
LLM_MODEL=gpt-3.5-turbo
LLM_MAX_TOKENS=2000
LLM_TEMPERATURE=0.7

# API Keys (set at least one)
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=your-anthropic-key-here

# NewsAPI key for fetching real news
NEWS_API_KEY=your-newsapi-key-here

# Database
# On Render.com: automatically set from PostgreSQL service via render.yaml
# For local development: use SQLite
DATABASE_URL=sqlite:///./manus_agent.db
# For local PostgreSQL: postgresql://user:pass@localhost/maxus

# Redis
# On Render.com: automatically set from Redis service via render.yaml
# For local development: use local Redis
REDIS_URL=redis://localhost:6379/0

# CORS (comma-separated origins, or * for all)
ALLOWED_ORIGINS=["*"]

# Social Media (optional - add later if needed)
# TWITTER_API_KEY=your-twitter-key
# TWITTER_API_SECRET=your-twitter-secret
# FACEBOOK_ACCESS_TOKEN=your-facebook-token
